{
  "name": "@pablofmorales/kuma-cli",
  "version": "1.5.1",
  "description": "CLI for managing Uptime Kuma via Socket.IO API",
  "bin": {
    "kuma": "dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "release": "semantic-release",
    "release:dry": "semantic-release --dry-run"
  },
  "keywords": [
    "uptime-kuma",
    "cli",
    "monitoring"
  ],
  "author": "Pablo Morales",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pablofmorales/kuma-cli.git"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "conf": "^15.1.0",
    "enquirer": "^2.4.1",
    "js-yaml": "^4.1.1",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.0",
    "conventional-changelog-conventionalcommits": "^9.3.0",
    "semantic-release": "^25.0.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  }
}
